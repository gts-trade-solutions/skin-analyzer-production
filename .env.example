# ── Auth (Auth.js / NextAuth) ──────────────────────────────────
# Secret for signing sessions. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=
# Public base URL of the app (used for verification links + OAuth callbacks).
AUTH_URL=http://localhost:3000
# Google OAuth app. Redirect URI: {AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Admin account(s): see all history/compare, grant analyses, view user details.
# Add multiple admins by separating emails with commas.
ADMIN_EMAIL=
# Verified AWS SES sender for verification emails (uses the AWS_* creds below;
# that IAM user also needs ses:SendEmail).
SES_FROM_EMAIL=

# ── Database (MySQL) ───────────────────────────────────────────
DATABASE_URL="mysql://user:password@localhost:3306/skin_analyzer"

# ── Amazon S3 (private bucket for face/hair images) ────────────
AWS_REGION=ap-south-1
AWS_S3_BUCKET=your-private-bucket-name
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Face detection gate: Face++ (free) ────────────────────────
# Verifies a face before the paid skin analysis. From the Face++ console.
FACEPP_API_KEY=
FACEPP_API_SECRET=
FACEPP_API_BASE=https://api-us.faceplusplus.com

# ── Skin analysis: Perfect Corp (YouCam) ──────────────────────
# Pay-per-use credits. From the Perfect Corp developer console.
PERFECTCORP_CLIENT_ID=
PERFECTCORP_CLIENT_SECRET=
PERFECTCORP_API_BASE=https://yce-api-01.makeupar.com

# Set to "true" ONLY to demo the flow without a provider (returns canned results
# regardless of the uploaded image). Leave unset/false for real analysis.
ANALYZER_MOCK=false

# ── madenkorea integration (Phase 5 — leave as-is for MVP) ─────
# Shared secret for verifying the inbound handoff token and signing the
# result post-back. Keep INTEGRATION_ENABLED=false until both ends are wired.
MADENKOREA_SHARED_SECRET=
INTEGRATION_ENABLED=false
